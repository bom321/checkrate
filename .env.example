# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง — ห้าม commit .env เข้า git

# ── SMTP (ส่งอีเมลแจ้งเตือน) ──
# Gmail: เปิด 2FA ก่อน แล้วสร้าง App Password ที่ https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM=your_email@gmail.com

# ผู้รับเริ่มต้น (คั่นหลายคนด้วย , ) — แก้ภายหลังผ่านหน้าเว็บได้ (จะถูกเก็บใน settings.json แทน)
EMAIL_TO=bom321@hotmail.com

# ── เว็บ ──
WEB_HOST=0.0.0.0
WEB_PORT=8080

# ── NAS / Docker ──
# path บน NAS ที่จะ map เข้า /data ใน container (CSV/PDF/log/config เก็บที่นี่ ปรับได้ตามต้องการ)
HOST_DATA_DIR=/volume1/deposit-rate

TZ=Asia/Bangkok
